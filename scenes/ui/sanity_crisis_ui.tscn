[node name="Title" type="Label" parent="Panel/VBox"]
text = "The Mind Breaks"
theme_override_colors/font_color = Color(0.95, 0.85, 0.6, 1)
theme_override_font_sizes/font_size = 22
horizontal_alignment = 1

[node name="Separator" type="HSeparator" parent="Panel/VBox"]

[node name="Body" type="Label" parent="Panel/VBox"]
text = "Guglielmo can no longer trust what he sees. The shadows move with purpose. The faces are wrong. Something watches from the spaces between moments.

Seek refuge and let the clergy tend to his mind — or press on into the dark."
theme_override_colors/font_color = Color(0.88, 0.78, 0.6, 1)
theme_override_font_sizes/font_size = 13
autowrap_mode = 3
custom_minimum_size = Vector2(0, 80)

[node name="Buttons" type="HBoxContainer" parent="Panel/VBox"]
alignment = 1
theme_override_constants/separation = 16

[node name="AsylumButton" type="Button" parent="Panel/VBox/Buttons"]
custom_minimum_size = Vector2(180, 40)
text = "Seek Asylum"
theme_override_colors/font_color = Color(0.95, 0.78, 0.55, 1)
theme_override_font_sizes/font_size = 14
theme_override_styles/normal = SubResource("StyleBoxFlat_btn_asylum")

[node name="PressOnButton" type="Button" parent="Panel/VBox/Buttons"]
custom_minimum_size = Vector2(180, 40)
