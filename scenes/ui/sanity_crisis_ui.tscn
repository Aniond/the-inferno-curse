theme_override_colors/font_color = Color(0.78, 0.7, 0.58, 1)
theme_override_font_sizes/font_size = 14
theme_override_styles/normal = SubResource("StyleBoxFlat_btn_press_on")

[node name="Consequence" type="Label" parent="Panel/VBox"]
text = "Asylum: sanity restored, but the mind is diminished.       Press On: keep your power. Keep your madness."
theme_override_colors/font_color = Color(0.55, 0.48, 0.38, 1)
theme_override_font_sizes/font_size = 11
autowrap_mode = 3
horizontal_alignment = 1
